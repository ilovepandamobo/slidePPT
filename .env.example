# 数据库（本地 SQLite；云端建议挂载卷后使用 file:/data/slidecraft.db）
DATABASE_URL="file:./prisma/dev.db"

# 会话密钥（生产环境务必改为随机长字符串）
JWT_SECRET="请替换为随机密钥"

# 站点公网地址（分享链接、参考图公网 URL 依赖此项）
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 标准 1K 生图（GrsAI Draw）
GRSAI_API_KEY=""
GRSAI_BASE_URL="https://grsai.dakka.com.cn"
GRSAI_MODEL="gpt-image-2"

# 大纲高清 4K（乘丰 Feng AI — DALL·E 格式，默认 api.cphone.vip）
GRSAI_IMAGES_API_KEY=""
GRSAI_IMAGES_BASE_URL="https://api.cphone.vip"
GRSAI_IMAGES_MODEL="gpt-image-2-vip"
# GRSAI_IMAGES_TIMEOUT_MS=540000

# 可选：OpenAI 大纲助手 / DALL·E 备用
OPENAI_API_KEY=""

# 可选：生成并发与轮询
# GENERATION_CONCURRENCY=3
# GRSAI_POLL_ATTEMPTS=180
# GRSAI_GENERATE_RETRIES=1

# Docker 首次启动是否写入演示账号（demo@slidecraft.app / demo123456）
# RUN_SEED="true"
